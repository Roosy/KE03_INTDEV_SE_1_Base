@page
@model IndexModel
@{
    ViewData["Title"] = "Home page";
}
<section class="hero">
    <h1>Matrix INC.</h1>
    <p>Mechanische onderdelen voor klanten van Matrix INC.</p>
    <a class="btn" href="/Catalog">Bekijk producten</a>
</section>

<section class="section-title">
    <h2>Voordeelproducten</h2>
    <p>Drie aanbiedingen uit de catalogus.</p>
</section>

<div class="deal-grid">
    <article class="product-card">
        <div class="product-photo">Tandwiel</div>
        <span class="label">Voordeel</span>
        <h3>Tandwiel staal</h3>
        <p class="price">&euro;24,95 <span>&euro;29,95</span></p>
    </article>

    <article class="product-card">
        <div class="product-photo">Boutjes</div>
        <span class="label">Voordeel</span>
        <h3>M5 Boutjes set</h3>
        <p class="price">&euro;8,50 <span>&euro;10,00</span></p>
    </article>

    <article class="product-card">
        <div class="product-photo">Pomp</div>
        <span class="label">Voordeel</span>
        <h3>Koelvloeistofpomp</h3>
        <p class="price">&euro;54,95 <span>&euro;64,95</span></p>
    </article>
</div