@page
@{
    ViewData["Title"] = "Winkelwagen";
}

<h1>Winkelwagen</h1>
<p class="intro">Controleer je bestelling voordat je deze plaatst.</p>

<div class="empty-message hidden" id="emptyCart">
    Je winkelwagen is leeg.
</div>

<table class="cart-table hidden" id="cartTable">
    <thead>
        <tr>
            <th>Product</th>
            <th>Prijs</th>
            <th>Aantal</th>
            <th>Subtotaal</th>
            <th></th>
        </tr>
    </thead>
    <tbody id="cartLines"></tbody>
    <tfoot>
        <tr>
            <th colspan="3">Totaal</th>
            <th id="cartTotal"></th>
            <th></th>
        </tr>
    </tfoot>
</table>

<button class="btn hidden" id="placeOrderButton">Bestelling Plaatsen</button>

<div class="toast-message hidden" id="toast"></div>