<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Matrix INC.</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <header class="topbar">
        <a class="brand" href="/">Matrix INC.</a>

        <nav>
            <a href="/">Home</a>
            <a href="/categorie">producten</a>
            <a href="/Orderhistorie">Orderhistorie</a>
        </nav>
    </header>

    <main class="page">
        @RenderBody()
    </main>

    <a class="cart-button" href="/Bestelling" aria-label="Winkelwagen">
        &#128722;
        <span id="cartCount">0</span>
    </a>

    <footer>
        Matrix INC.
    </footer>

    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>